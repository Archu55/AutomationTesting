{
  "name": "wdio-practice",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@wdio/allure-reporter": "^9.22.0",
    "@wdio/cli": "^9.22.0",
    "@wdio/cucumber-framework": "^9.22.0",
    "@wdio/local-runner": "^9.22.0",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/visual-service": "^9.1.0",
    "allure-commandline": "^2.36.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-wdio": "^9.23.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  },
  "lint-staged": {
    "**/*.{js,json,yml,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "view-report": "allure open ./reports/allure-report",
    "test": "wdio run ./wdio.conf.js",
    "test:smoke": "set TAGS=@smoke&& wdio run wdio.conf.js",
    "test:headless": "set HEADLESS=true&& wdio run wdio.conf.js",
    "prepare": "husky",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "qa:check": "npm run lint && npm run format",
    "qa:fix": "npm run lint:fix && npm run format:fix"
  }
}
